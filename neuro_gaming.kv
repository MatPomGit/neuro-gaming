#: kivy 2.3.0
# neuro_gaming.kv – Professional Muse S Athena Control Interface

# ─────────────────────────────────────────────────────────────────────────────
# Shared Styles and Widgets
# ─────────────────────────────────────────────────────────────────────────────

<DirectionButton@Label>:
    label: ''
    active: False
    text: self.label
    font_size: '32sp'
    bold: True
    halign: 'center'
    valign: 'middle'
    color: (1, 1, 1, 1)
    canvas.before:
        # Active direction highlight
        Color:
            rgba: (0.18, 0.55, 1.0, 0.3) if self.active else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.x - 2, self.y - 2
            size: self.width + 4, self.height + 4
            radius: [8]
        # Button background
        Color:
            rgba: (0.18, 0.55, 1.0, 1.0) if self.active else (0.12, 0.12, 0.18, 1.0)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [6]

<BandBar@BoxLayout>:
    channel: ''
    band: 'ALPHA'
    value: 0.0
    orientation: 'vertical'
    spacing: 4
    Label:
        text: f"{root.channel}\n{root.band}"
        font_size: '9sp'
        bold: True
        size_hint_y: None
        height: '32dp'
        color: (0.6, 0.6, 0.7, 1)
        halign: 'center'
    Widget:
        canvas:
            Color:
                rgba: (0.08, 0.08, 0.12, 1)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [2]
            Color:
                rgba: (0.2, 0.7, 1.0, 1) if root.band == 'ALPHA' else (0.9, 0.5, 0.1, 1)
            Rectangle:
                pos: self.pos
                size: self.width * max(0, min(1.0, root.value)), self.height

<QualityBar@BoxLayout>:
    channel: ''
    quality: 0.0
    orientation: 'vertical'
    spacing: 4
    Label:
        text: root.channel
        font_size: '9sp'
        bold: True
        size_hint_y: None
        height: '24dp'
        color: (0.6, 0.6, 0.7, 1)
        halign: 'center'
    Widget:
        canvas:
            Color:
                rgba: (0.08, 0.08, 0.12, 1)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [2]
            Color:
                r: max(0.0, 1.0 - root.quality * 2.0)
                g: min(1.0, root.quality * 2.0) * 0.8
                b: 0.2
                a: 1.0
            Rectangle:
                pos: self.pos
                size: self.width * max(0, min(1.0, root.quality)), self.height

<DeviceRow@Button>:
    index: 0
    size_hint_y: None
    height: '60dp'
    background_normal: ''
    background_color: (0.12, 0.12, 0.18, 1)
    color: (0.8, 0.8, 0.9, 1)
    font_size: '14sp'
    text_size: self.width - dp(32), None
    halign: 'center'
    valign: 'middle'
    canvas.after:
        Color:
            rgba: (1, 1, 1, 0.05)
        Line:
            points: [self.x, self.y, self.x + self.width, self.y]
            width: 1
    on_release: app.root.get_screen('scan').connect_device(self.index)

# ─────────────────────────────────────────────────────────────────────────────
# Scan / Configuration Screen
# ─────────────────────────────────────────────────────────────────────────────

<ScanScreen>:
    canvas.before:
        Color:
            rgba: (0.04, 0.04, 0.06, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: [24, 32, 24, 24]
        spacing: 20

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: '70dp'
            Label:
                text: 'NEURO GAMING INTERFACE'
                font_size: '24sp'
                bold: True
                color: (1, 1, 1, 1)
                halign: 'center'
            Label:
                text: 'SYSTEM VERSION ' + app.version
                font_size: '10sp'
                color: (0.4, 0.4, 0.5, 1)
                halign: 'center'

        # Main horizontal container for Device List and Console
        BoxLayout:
            orientation: 'horizontal'
            spacing: 24

            # Left Column: Device Discovery
            BoxLayout:
                orientation: 'vertical'
                spacing: 12
                size_hint_x: 0.5

                Label:
                    text: root.status_text.upper()
                    font_size: '11sp'
                    size_hint_y: None
                    height: '24dp'
                    color: root.fsm_color
                    halign: 'center'

                Button:
                    text: root.fsm_state if root.is_scanning else 'SCAN FOR DEVICES'
                    size_hint_y: None
                    height: '48dp'
                    font_size: '13sp'
                    bold: True
                    background_normal: ''
                    background_color: (0.18, 0.55, 1.0, 1)
                    opacity: root.scan_pulse
                    disabled: root.is_scanning
                    on_release: root.scan()

                Label:
                    text: f'FOUND DEVICES: {root.found_devices_count}'
                    font_size: '10sp'
                    size_hint_y: None
                    height: '18dp'
                    color: (0.45, 0.45, 0.55, 1)
                    halign: 'left'
                    text_size: self.size

                ScrollView:
                    size_hint_y: 1
                    canvas.before:
                        Color:
                            rgba: (0, 0, 0, 0.2)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    RecycleView:
                        id: device_list
                        data: [{'text': n, 'index': i} for i, n in enumerate(root.device_names)]
                        viewclass: 'DeviceRow'
                        RecycleBoxLayout:
                            orientation: 'vertical'
                            default_size: None, dp(60)
                            default_size_hint: 1, None
                            size_hint_y: None
                            height: self.minimum_height

                BoxLayout:
                    size_hint_y: None
                    height: '196dp'
                    orientation: 'vertical'
                    spacing: 8
                    Label:
                        text: 'TIP: If one Muse is found, app can auto-connect.'
                        size_hint_y: None
                        height: '32dp'
                        font_size: '10sp'
                        color: (0.5, 0.5, 0.6, 1)
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                    Button:
                        text: 'VIRTUAL KEYBOARD MODE'
                        size_hint_y: None
                        height: '44dp'
                        font_size: '12sp'
                        background_normal: ''
                        background_color: (0.15, 0.15, 0.2, 1)
                        on_release: root.skip_to_keyboard()
                    Button:
                        text: 'OPEN DIAGNOSTICS SCREEN'
                        size_hint_y: None
                        height: '44dp'
                        font_size: '12sp'
                        background_normal: ''
                        background_color: (0.1, 0.35, 0.2, 1)
                        on_release: root.go_to_test()
                    Button:
                        text: 'CLOSE APP'
                        size_hint_y: None
                        height: '44dp'
                        font_size: '12sp'
                        background_normal: ''
                        background_color: (0.45, 0.12, 0.12, 1)
                        on_release: root.close_app()

            # Right Column: Terminal Output (Live Console)
            BoxLayout:
                orientation: 'vertical'
                spacing: 8
                size_hint_x: 0.5

                Label:
                    text: 'LIVE TERMINAL OUTPUT & BLE DIAGNOSTICS'
                    font_size: '10sp'
                    bold: True
                    size_hint_y: None
                    height: '24dp'
                    color: (0.5, 0.5, 0.6, 1)
                    halign: 'left'
                    text_size: self.size

                ScrollView:
                    id: terminal_scroll
                    do_scroll_x: False
                    bar_width: '6dp'
                    scroll_y: 0  # Always scroll to bottom
                    canvas.before:
                        Color:
                            rgba: (0.06, 0.06, 0.09, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [4]
                        Color:
                            rgba: (1, 1, 1, 0.03)
                        Line:
                            rounded_rectangle: [self.x, self.y, self.width, self.height, 4]
                            width: 1
                    Label:
                        text: app.console_output if app.console_output else 'Waiting for BLE events...'
                        font_name: 'Roboto'  # Standard mono-ish font
                        font_size: '10sp'
                        color: (0.2, 0.8, 0.4, 1)  # Matrix green for terminal feel
                        halign: 'left'
                        valign: 'top'
                        size_hint_y: None
                        text_size: self.width - dp(16), None
                        height: max(self.texture_size[1] + dp(16), self.parent.height)

# ─────────────────────────────────────────────────────────────────────────────
# Primary Operational Screen
# ─────────────────────────────────────────────────────────────────────────────

<GameScreen>:
    canvas.before:
        Color:
            rgba: (0.04, 0.04, 0.06, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: [20, 16, 20, 16]
        spacing: 16

        # Status Bar
        BoxLayout:
            size_hint_y: None
            height: '36dp'
            padding: [12, 0, 12, 0]
            canvas.before:
                Color:
                    rgba: (0.1, 0.1, 0.15, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: 'INPUT: ' + ('EEG' if root.connected else 'KEYBOARD')
                font_size: '11sp'
                bold: True
                size_hint_x: None
                width: '120dp'
                color: (0.2, 0.7, 1.0, 1) if root.connected else (0.9, 0.5, 0.1, 1)
                halign: 'left'
            Label:
                text: root.status_text.upper()
                font_size: '11sp'
                color: (0.6, 0.6, 0.7, 1)
                halign: 'right'

        BoxLayout:
            size_hint_y: None
            height: '44dp'
            spacing: 10
            padding: [10, 0, 10, 0]
            canvas.before:
                Color:
                    rgba: (0.08, 0.08, 0.12, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [4]
            Label:
                text: root.device_text
                font_size: '10sp'
                color: (0.72, 0.78, 0.88, 1)
                halign: 'left'
                text_size: self.size
            Label:
                text: root.battery_text
                font_size: '10sp'
                color: (0.72, 0.78, 0.88, 1)
                halign: 'center'
                text_size: self.size
            Label:
                text: root.sensors_text
                font_size: '10sp'
                color: (0.72, 0.78, 0.88, 1)
                halign: 'right'
                text_size: self.size

        BoxLayout:
            size_hint_y: None
            height: '40dp'
            spacing: 10
            padding: [10, 0, 10, 0]
            canvas.before:
                Color:
                    rgba: (0.08, 0.08, 0.12, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [4]
            Label:
                text: root.stream_status_text
                font_size: '9sp'
                color: (0.72, 0.78, 0.88, 1)
                halign: 'left'
                text_size: self.size
            Label:
                text: root.motion_text
                font_size: '9sp'
                color: (1.0, 0.65, 0.2, 1) if 'artifact' in root.motion_text.lower() else (0.3, 0.9, 0.5, 1)
                halign: 'center'
                text_size: self.size
            Label:
                text: root.eeg_quality_text
                font_size: '9sp'
                color: (0.72, 0.78, 0.88, 1)
                halign: 'right'
                text_size: self.size

        # Directional Controls
        GridLayout:
            cols: 3
            rows: 3
            spacing: 16
            size_hint_y: 0.45
            padding: [40, 0, 40, 0]

            Widget:
            DirectionButton:
                label: 'UP'
                active: root.direction == 'FORWARD'
            Widget:

            DirectionButton:
                label: 'LEFT'
                active: root.direction == 'LEFT'
            Label:
                text: root.direction if root.direction != 'NONE' else 'STANDBY'
                font_size: '12sp'
                bold: True
                color: (0.4, 0.4, 0.5, 1)
                halign: 'center'
            DirectionButton:
                label: 'RIGHT'
                active: root.direction == 'RIGHT'

            Widget:
            DirectionButton:
                label: 'DOWN'
                active: root.direction == 'BACKWARD'
            Widget:

        # Telemetry Panel
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 0.35
            spacing: 24

            # EEG Metrics
            BoxLayout:
                orientation: 'vertical'
                spacing: 8
                Label:
                    text: 'EEG BAND INTENSITY'
                    font_size: '10sp'
                    bold: True
                    size_hint_y: None
                    height: '20dp'
                    color: (0.5, 0.5, 0.6, 1)
                BoxLayout:
                    spacing: 10
                    BandBar:
                        channel: 'AF7'
                        band: 'ALPHA'
                        value: root.alpha_left
                    BandBar:
                        channel: 'AF8'
                        band: 'ALPHA'
                        value: root.alpha_right
                    BandBar:
                        channel: 'AF7'
                        band: 'BETA'
                        value: root.beta_left
                    BandBar:
                        channel: 'AF8'
                        band: 'BETA'
                        value: root.beta_right

            # Signal Health
            BoxLayout:
                orientation: 'vertical'
                spacing: 8
                Label:
                    text: 'JAKOŚĆ KONTAKTU SENSORÓW'
                    font_size: '10sp'
                    bold: True
                    size_hint_y: None
                    height: '20dp'
                    color: (0.5, 0.5, 0.6, 1)
                BoxLayout:
                    spacing: 10
                    QualityBar:
                        channel: 'TP9'
                        quality: root.quality_tp9
                    QualityBar:
                        channel: 'AF7'
                        quality: root.quality_af7
                    QualityBar:
                        channel: 'AF8'
                        quality: root.quality_af8
                    QualityBar:
                        channel: 'TP10'
                        quality: root.quality_tp10

        # System Control Interface
        BoxLayout:
            size_hint_y: None
            height: '50dp'
            spacing: 12

            Button:
                text: 'SETTINGS'
                font_size: '12sp'
                bold: True
                background_normal: ''
                background_color: (0.15, 0.15, 0.2, 1)
                on_release: root.open_settings_popup()

            Button:
                text: 'OPEN CALIBRATION'
                font_size: '12sp'
                bold: True
                background_normal: ''
                background_color: (0.15, 0.15, 0.2, 1)
                on_release: root.toggle_calibration()

            Button:
                text: 'INPUT MODE: ' + root.key_mode.upper()
                font_size: '12sp'
                bold: True
                background_normal: ''
                background_color: (0.15, 0.15, 0.2, 1)
                on_release: root.toggle_key_mode()

            Button:
                text: 'DISCONNECT'
                font_size: '12sp'
                bold: True
                background_normal: ''
                background_color: (0.5, 0.1, 0.1, 1)
                on_release: root.disconnect()

            Button:
                text: 'CLOSE APP'
                font_size: '12sp'
                bold: True
                background_normal: ''
                background_color: (0.45, 0.12, 0.12, 1)
                on_release: root.close_app()

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: '120dp'
            spacing: 4
            Label:
                text: 'TERMINAL OUTPUT'
                font_size: '10sp'
                bold: True
                size_hint_y: None
                height: '18dp'
                color: (0.5, 0.5, 0.6, 1)
                halign: 'left'
                text_size: self.size
            ScrollView:
                do_scroll_x: False
                bar_width: '6dp'
                canvas.before:
                    Color:
                        rgba: (0.06, 0.06, 0.09, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [4]
                Label:
                    text: app.console_output if app.console_output else 'No logs yet.'
                    font_size: '10sp'
                    color: (0.7, 0.78, 0.85, 1)
                    halign: 'left'
                    valign: 'top'
                    size_hint_y: None
                    text_size: self.width - dp(10), None
                    height: max(self.texture_size[1] + dp(10), self.parent.height)

# ─────────────────────────────────────────────────────────────────────────────
# Calibration Wizard Screen
# ─────────────────────────────────────────────────────────────────────────────

<CalibrationScreen>:
    canvas.before:
        Color:
            rgba: (0.04, 0.04, 0.06, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: [28, 32, 28, 24]
        spacing: 18

        # ── Header ───────────────────────────────────────────────────────────
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: '56dp'
            Label:
                text: 'CALIBRATION WIZARD'
                font_size: '22sp'
                bold: True
                color: (1, 1, 1, 1)
                halign: 'center'
            Label:
                text: 'Follow the steps below to record your EEG baseline'
                font_size: '11sp'
                color: (0.45, 0.45, 0.55, 1)
                halign: 'center'

        # ── Step-by-step instruction list ────────────────────────────────────
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: '230dp'
            spacing: 6
            padding: [4, 0, 4, 0]
            canvas.before:
                Color:
                    rgba: (0.09, 0.09, 0.14, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [6]

            Label:
                text: 'HOW TO CALIBRATE'
                font_size: '10sp'
                bold: True
                size_hint_y: None
                height: '24dp'
                color: (0.35, 0.55, 0.9, 1)
                halign: 'center'

            # Step 1
            BoxLayout:
                size_hint_y: None
                height: '36dp'
                padding: [12, 2, 12, 2]
                canvas.before:
                    Color:
                        rgba: (0.18, 0.55, 1.0, 0.22) if root.current_step == 0 else (0, 0, 0, 0)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [4]
                Label:
                    text: root.steps[0]
                    font_size: '11sp'
                    color: (1, 1, 1, 1) if root.current_step == 0 else (0.55, 0.55, 0.65, 1)
                    bold: root.current_step == 0
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

            # Step 2
            BoxLayout:
                size_hint_y: None
                height: '36dp'
                padding: [12, 2, 12, 2]
                canvas.before:
                    Color:
                        rgba: (0.18, 0.55, 1.0, 0.22) if root.current_step == 1 else (0, 0, 0, 0)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [4]
                Label:
                    text: root.steps[1]
                    font_size: '11sp'
                    color: (1, 1, 1, 1) if root.current_step == 1 else (0.55, 0.55, 0.65, 1)
                    bold: root.current_step == 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

            # Step 3
            BoxLayout:
                size_hint_y: None
                height: '36dp'
                padding: [12, 2, 12, 2]
                canvas.before:
                    Color:
                        rgba: (0.18, 0.55, 1.0, 0.22) if root.current_step == 2 else (0, 0, 0, 0)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [4]
                Label:
                    text: root.steps[2]
                    font_size: '11sp'
                    color: (1, 1, 1, 1) if root.current_step == 2 else (0.55, 0.55, 0.65, 1)
                    bold: root.current_step == 2
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

            # Step 4
            BoxLayout:
                size_hint_y: None
                height: '36dp'
                padding: [12, 2, 12, 2]
                canvas.before:
                    Color:
                        rgba: (0.18, 0.55, 1.0, 0.22) if root.current_step == 3 else (0, 0, 0, 0)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [4]
                Label:
                    text: root.steps[3]
                    font_size: '11sp'
                    color: (1, 1, 1, 1) if root.current_step == 3 else (0.55, 0.55, 0.65, 1)
                    bold: root.current_step == 3
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

            # Step 5
            BoxLayout:
                size_hint_y: None
                height: '36dp'
                padding: [12, 2, 12, 2]
                canvas.before:
                    Color:
                        rgba: (0.18, 0.55, 1.0, 0.22) if root.current_step == 4 else (0, 0, 0, 0)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [4]
                Label:
                    text: root.steps[4]
                    font_size: '11sp'
                    color: (0.3, 0.9, 0.5, 1) if root.calibration_done else ((1, 1, 1, 1) if root.current_step == 4 else (0.55, 0.55, 0.65, 1))
                    bold: root.current_step == 4
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

        # ── Signal quality display ────────────────────────────────────────────
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: '90dp'
            spacing: 6
            canvas.before:
                Color:
                    rgba: (0.09, 0.09, 0.14, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [6]
            Label:
                text: 'JAKOŚĆ KONTAKTU SENSORÓW'
                font_size: '10sp'
                bold: True
                size_hint_y: None
                height: '22dp'
                color: (0.5, 0.5, 0.6, 1)
                halign: 'center'
            BoxLayout:
                spacing: 12
                padding: [12, 0, 12, 8]
                QualityBar:
                    channel: 'TP9'
                    quality: root.quality_tp9
                QualityBar:
                    channel: 'AF7'
                    quality: root.quality_af7
                QualityBar:
                    channel: 'AF8'
                    quality: root.quality_af8
                QualityBar:
                    channel: 'TP10'
                    quality: root.quality_tp10

        # ── Calibration progress ──────────────────────────────────────────────
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: '64dp'
            spacing: 6
            # Progress bar background
            canvas.before:
                Color:
                    rgba: (0.09, 0.09, 0.14, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [6]
            Label:
                text: root.status_text
                font_size: '11sp'
                color: (0.3, 0.9, 0.5, 1) if root.calibration_done else (0.75, 0.75, 0.85, 1)
                halign: 'center'
                bold: root.calibration_done
            # Timer bar
            Widget:
                size_hint_y: None
                height: '10dp'
                canvas:
                    Color:
                        rgba: (0.08, 0.08, 0.12, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [3]
                    Color:
                        rgba: (0.3, 0.9, 0.5, 1) if root.calibration_done else (0.18, 0.55, 1.0, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.width * (1.0 - root.timer_value / root.calibration_duration) if root.is_calibrating else (self.width if root.calibration_done else 0), self.height
                        radius: [3]

        # ── Control buttons ───────────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: '52dp'
            spacing: 12

            Button:
                text: 'KALIBRACJA…' if root.is_calibrating else ('KALIBRUJ PONOWNIE' if root.calibration_done else 'START KALIBRACJI')
                font_size: '13sp'
                bold: True
                background_normal: ''
                background_color: (0.55, 0.25, 0.08, 1) if root.is_calibrating else (0.18, 0.55, 1.0, 1)
                disabled: root.is_calibrating
                on_release: root.start_calibration()

            Button:
                text: 'POWRÓT DO GRY'
                font_size: '13sp'
                bold: True
                background_normal: ''
                background_color: (0.15, 0.15, 0.2, 1)
                on_release: root.go_back()

# ─────────────────────────────────────────────────────────────────────────────
# Diagnostics Screen
# ─────────────────────────────────────────────────────────────────────────────

<TestScreen>:
    canvas.before:
        Color:
            rgba: (0.02, 0.02, 0.03, 1)
        Rectangle:
            pos: self.pos
            size: self.size
        # Technical grid
        Color:
            rgba: (0.18, 0.55, 1, 0.05)
        Line:
            points: sum([[x, 0, x, self.height] for x in range(0, int(self.width), 80)], [])
            width: 1
        Line:
            points: sum([[0, y, self.width, y] for y in range(0, int(self.height), 80)], [])
            width: 1

        # Test object (dot)
        Color:
            rgba: root.dot_color
        Ellipse:
            pos: root.dot_x - root.dot_radius, root.dot_y - root.dot_radius
            size: root.dot_radius * 2, root.dot_radius * 2

    BoxLayout:
        orientation: 'vertical'
        padding: [24, 20, 24, 24]
        spacing: 12

        Label:
            text: 'CONTROL DIAGNOSTICS + SESSION REPLAY'
            font_size: '18sp'
            bold: True
            size_hint_y: None
            height: '40dp'
            color: (1, 1, 1, 1)

        Label:
            text: root.recorder_status
            font_size: '11sp'
            size_hint_y: None
            height: '22dp'
            color: (0.3, 0.85, 0.6, 1) if root.recording_active else (0.7, 0.7, 0.75, 1)

        Label:
            text: root.replay_status
            font_size: '11sp'
            size_hint_y: None
            height: '22dp'
            color: (0.45, 0.75, 1.0, 1)

        Widget:
            size_hint_y: 1

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: '160dp'
            padding: 16
            spacing: 8
            canvas.before:
                Color:
                    rgba: (0.1, 0.1, 0.15, 0.8)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [4]

            Label:
                text: root.status_text.upper()
                font_size: '11sp'
                color: (0.8, 0.8, 0.9, 1)

            BoxLayout:
                spacing: 20
                Label:
                    text: 'L-ACTION: ' + ('ACTIVE' if root.left_active else 'IDLE')
                    font_size: '11sp'
                    bold: True
                    color: (0.2, 0.8, 0.4, 1) if root.left_active else (0.4, 0.4, 0.5, 1)
                Label:
                    text: 'R-RESET: ' + ('ACTIVE' if root.right_active else 'IDLE')
                    font_size: '11sp'
                    bold: True
                    color: (0.8, 0.2, 0.2, 1) if root.right_active else (0.4, 0.4, 0.5, 1)

            BoxLayout:
                size_hint_y: None
                height: '40dp'
                spacing: 8
                Button:
                    text: 'STOP REC' if root.recording_active else 'START REC'
                    background_normal: ''
                    background_color: (0.75, 0.2, 0.2, 1) if root.recording_active else (0.18, 0.55, 1.0, 1)
                    on_release: root.toggle_recording()
                Button:
                    text: 'EXPORT CSV'
                    background_normal: ''
                    background_color: (0.12, 0.38, 0.22, 1)
                    on_release: root.export_recording_csv()
                Button:
                    text: 'REPLAY'
                    background_normal: ''
                    background_color: (0.28, 0.22, 0.52, 1)
                    on_release: root.start_replay()
                Button:
                    text: 'CLEAR'
                    background_normal: ''
                    background_color: (0.25, 0.25, 0.28, 1)
                    on_release: root.clear_recording()

            Button:
                text: 'EXIT DIAGNOSTICS'
                font_size: '12sp'
                bold: True
                size_hint_y: None
                height: '40dp'
                background_normal: ''
                background_color: (0.15, 0.15, 0.2, 1)
                on_release: root.go_back()
