#: kivy 2.3.0
# neuro_gaming.kv – Professional Muse S Athena Control Interface

# ─────────────────────────────────────────────────────────────────────────────
# Shared Styles and Widgets
# ─────────────────────────────────────────────────────────────────────────────

<DirectionButton@Label>:
    label: ''
    active: False
    text: self.label
    font_size: '32sp'
    bold: True
    halign: 'center'
    valign: 'middle'
    color: (1, 1, 1, 1)
    canvas.before:
        # Active direction highlight
        Color:
            rgba: (0.18, 0.55, 1.0, 0.3) if self.active else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.x - 2, self.y - 2
            size: self.width + 4, self.height + 4
            radius: [8]
        # Button background
        Color:
            rgba: (0.18, 0.55, 1.0, 1.0) if self.active else (0.12, 0.12, 0.18, 1.0)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [6]

<BandBar@BoxLayout>:
    channel: ''
    band: 'ALPHA'
    value: 0.0
    orientation: 'vertical'
    spacing: 4
    Label:
        text: f"{root.channel}\n{root.band}"
        font_size: '9sp'
        bold: True
        size_hint_y: None
        height: '32dp'
        color: (0.6, 0.6, 0.7, 1)
        halign: 'center'
    Widget:
        canvas:
            Color:
                rgba: (0.08, 0.08, 0.12, 1)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [2]
            Color:
                rgba: (0.2, 0.7, 1.0, 1) if root.band == 'ALPHA' else (0.9, 0.5, 0.1, 1)
            Rectangle:
                pos: self.pos
                size: self.width * max(0, min(1.0, root.value)), self.height

<QualityBar@BoxLayout>:
    channel: ''
    quality: 0.0
    orientation: 'vertical'
    spacing: 4
    Label:
        text: root.channel
        font_size: '9sp'
        bold: True
        size_hint_y: None
        height: '24dp'
        color: (0.6, 0.6, 0.7, 1)
        halign: 'center'
    Widget:
        canvas:
            Color:
                rgba: (0.08, 0.08, 0.12, 1)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [2]
            Color:
                r: max(0.0, 1.0 - root.quality * 2.0)
                g: min(1.0, root.quality * 2.0) * 0.8
                b: 0.2
                a: 1.0
            Rectangle:
                pos: self.pos
                size: self.width * max(0, min(1.0, root.quality)), self.height

<DeviceRow@Button>:
    index: 0
    size_hint_y: None
    height: '48dp'
    background_normal: ''
    background_color: (0.12, 0.12, 0.18, 1)
    color: (0.8, 0.8, 0.9, 1)
    font_size: '13sp'
    canvas.after:
        Color:
            rgba: (1, 1, 1, 0.05)
        Line:
            points: [self.x, self.y, self.x + self.width, self.y]
            width: 1
    on_release: app.root.get_screen('scan').connect_device(self.index)

# ─────────────────────────────────────────────────────────────────────────────
# Scan / Configuration Screen
# ─────────────────────────────────────────────────────────────────────────────

<ScanScreen>:
    canvas.before:
        Color:
            rgba: (0.04, 0.04, 0.06, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: [32, 40, 32, 32]
        spacing: 20

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: '70dp'
            Label:
                text: 'NEURO GAMING INTERFACE'
                font_size: '24sp'
                bold: True
                color: (1, 1, 1, 1)
                halign: 'center'
            Label:
                text: 'SYSTEM VERSION ' + app.version
                font_size: '10sp'
                color: (0.4, 0.4, 0.5, 1)
                halign: 'center'

        Label:
            text: root.status_text.upper()
            font_size: '12sp'
            size_hint_y: None
            height: '30dp'
            color: (0.7, 0.7, 0.8, 1)
            halign: 'center'

        Button:
            text: 'SCANNING...' if root.is_scanning else 'SCAN FOR DEVICES'
            size_hint_y: None
            height: '52dp'
            font_size: '14sp'
            bold: True
            background_normal: ''
            background_color: (0.18, 0.55, 1.0, 1)
            opacity: root.scan_pulse
            on_release: root.scan()

        ScrollView:
            size_hint_y: 1
            canvas.before:
                Color:
                    rgba: (0, 0, 0, 0.2)
                Rectangle:
                    pos: self.pos
                    size: self.size
            RecycleView:
                id: device_list
                data: [{'text': n, 'index': i} for i, n in enumerate(root.device_names)]
                viewclass: 'DeviceRow'
                RecycleBoxLayout:
                    orientation: 'vertical'
                    default_size: None, dp(48)
                    default_size_hint: 1, None
                    size_hint_y: None
                    height: self.minimum_height

        BoxLayout:
            size_hint_y: None
            height: '100dp'
            orientation: 'vertical'
            spacing: 8
            Button:
                text: 'VIRTUAL KEYBOARD MODE'
                size_hint_y: None
                height: '44dp'
                font_size: '13sp'
                background_normal: ''
                background_color: (0.15, 0.15, 0.2, 1)
                on_release: root.skip_to_keyboard()
            Button:
                text: 'OPEN DIAGNOSTICS SCREEN'
                size_hint_y: None
                height: '44dp'
                font_size: '13sp'
                background_normal: ''
                background_color: (0.1, 0.35, 0.2, 1)
                on_release: root.go_to_test()

# ─────────────────────────────────────────────────────────────────────────────
# Primary Operational Screen
# ─────────────────────────────────────────────────────────────────────────────

<GameScreen>:
    canvas.before:
        Color:
            rgba: (0.04, 0.04, 0.06, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: [20, 16, 20, 16]
        spacing: 16

        # Status Bar
        BoxLayout:
            size_hint_y: None
            height: '36dp'
            padding: [12, 0, 12, 0]
            canvas.before:
                Color:
                    rgba: (0.1, 0.1, 0.15, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: 'INPUT: ' + ('EEG' if root.connected else 'KEYBOARD')
                font_size: '11sp'
                bold: True
                size_hint_x: None
                width: '120dp'
                color: (0.2, 0.7, 1.0, 1) if root.connected else (0.9, 0.5, 0.1, 1)
                halign: 'left'
            Label:
                text: root.status_text.upper()
                font_size: '11sp'
                color: (0.6, 0.6, 0.7, 1)
                halign: 'right'

        # Directional Controls
        GridLayout:
            cols: 3
            rows: 3
            spacing: 16
            size_hint_y: 0.45
            padding: [40, 0, 40, 0]

            Widget:
            DirectionButton:
                label: 'UP'
                active: root.direction == 'FORWARD'
            Widget:

            DirectionButton:
                label: 'LEFT'
                active: root.direction == 'LEFT'
            Label:
                text: root.direction if root.direction != 'NONE' else 'STANDBY'
                font_size: '12sp'
                bold: True
                color: (0.4, 0.4, 0.5, 1)
                halign: 'center'
            DirectionButton:
                label: 'RIGHT'
                active: root.direction == 'RIGHT'

            Widget:
            DirectionButton:
                label: 'DOWN'
                active: root.direction == 'BACKWARD'
            Widget:

        # Telemetry Panel
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 0.35
            spacing: 24

            # EEG Metrics
            BoxLayout:
                orientation: 'vertical'
                spacing: 8
                Label:
                    text: 'EEG BAND INTENSITY'
                    font_size: '10sp'
                    bold: True
                    size_hint_y: None
                    height: '20dp'
                    color: (0.5, 0.5, 0.6, 1)
                BoxLayout:
                    spacing: 10
                    BandBar:
                        channel: 'AF7'
                        band: 'ALPHA'
                        value: root.alpha_left
                    BandBar:
                        channel: 'AF8'
                        band: 'ALPHA'
                        value: root.alpha_right
                    BandBar:
                        channel: 'AF7'
                        band: 'BETA'
                        value: root.beta_left
                    BandBar:
                        channel: 'AF8'
                        band: 'BETA'
                        value: root.beta_right

            # Signal Health
            BoxLayout:
                orientation: 'vertical'
                spacing: 8
                Label:
                    text: 'SENSOR CONTACT QUALITY'
                    font_size: '10sp'
                    bold: True
                    size_hint_y: None
                    height: '20dp'
                    color: (0.5, 0.5, 0.6, 1)
                BoxLayout:
                    spacing: 10
                    QualityBar:
                        channel: 'TP9'
                        quality: root.quality_tp9
                    QualityBar:
                        channel: 'AF7'
                        quality: root.quality_af7
                    QualityBar:
                        channel: 'AF8'
                        quality: root.quality_af8
                    QualityBar:
                        channel: 'TP10'
                        quality: root.quality_tp10

        # System Control Interface
        BoxLayout:
            size_hint_y: None
            height: '50dp'
            spacing: 12

            Button:
                text: 'STOP CALIBRATION' if root.is_calibrating else 'START CALIBRATION'
                font_size: '12sp'
                bold: True
                background_normal: ''
                background_color: (0.7, 0.3, 0.1, 1) if root.is_calibrating else (0.15, 0.15, 0.2, 1)
                on_release: root.toggle_calibration()

            Button:
                text: 'INPUT MODE: ' + root.key_mode.upper()
                font_size: '12sp'
                bold: True
                background_normal: ''
                background_color: (0.15, 0.15, 0.2, 1)
                on_release: root.toggle_key_mode()

            Button:
                text: 'DISCONNECT'
                font_size: '12sp'
                bold: True
                background_normal: ''
                background_color: (0.5, 0.1, 0.1, 1)
                on_release: root.disconnect()

# ─────────────────────────────────────────────────────────────────────────────
# Diagnostics Screen
# ─────────────────────────────────────────────────────────────────────────────

<TestScreen>:
    canvas.before:
        Color:
            rgba: (0.02, 0.02, 0.03, 1)
        Rectangle:
            pos: self.pos
            size: self.size
        # Technical grid
        Color:
            rgba: (0.18, 0.55, 1, 0.05)
        Line:
            points: [x, 0, x, self.height] for x in range(0, int(self.width), 80)
            width: 1
        Line:
            points: [0, y, self.width, y] for y in range(0, int(self.height), 80)
            width: 1

        # Test object (dot)
        Color:
            rgba: root.dot_color
        Ellipse:
            pos: root.dot_x - root.dot_radius, root.dot_y - root.dot_radius
            size: root.dot_radius * 2, root.dot_radius * 2

    BoxLayout:
        orientation: 'vertical'
        padding: [24, 20, 24, 24]
        spacing: 12

        Label:
            text: 'CONTROL DIAGNOSTICS'
            font_size: '18sp'
            bold: True
            size_hint_y: None
            height: '40dp'
            color: (1, 1, 1, 1)

        Widget:
            size_hint_y: 1

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: '110dp'
            padding: 16
            spacing: 8
            canvas.before:
                Color:
                    rgba: (0.1, 0.1, 0.15, 0.8)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [4]

            Label:
                text: root.status_text.upper()
                font_size: '11sp'
                color: (0.8, 0.8, 0.9, 1)

            BoxLayout:
                spacing: 20
                Label:
                    text: 'L-ACTION: ' + ('ACTIVE' if root.left_active else 'IDLE')
                    font_size: '11sp'
                    bold: True
                    color: (0.2, 0.8, 0.4, 1) if root.left_active else (0.4, 0.4, 0.5, 1)
                Label:
                    text: 'R-RESET: ' + ('ACTIVE' if root.right_active else 'IDLE')
                    font_size: '11sp'
                    bold: True
                    color: (0.8, 0.2, 0.2, 1) if root.right_active else (0.4, 0.4, 0.5, 1)

            Button:
                text: 'EXIT DIAGNOSTICS'
                font_size: '12sp'
                bold: True
                size_hint_y: None
                height: '40dp'
                background_normal: ''
                background_color: (0.15, 0.15, 0.2, 1)
                on_release: root.go_back()
