#: kivy 2.3.0
# neuro_gaming.kv – Layout for the NeuroGaming Muse S Athena controller app

# ─────────────────────────────────────────────────────────────────────────────
# Reusable widgets
# ─────────────────────────────────────────────────────────────────────────────

<DirectionButton@Label>:
    label: ''
    active: False
    text: self.label
    font_size: '36sp'
    bold: True
    halign: 'center'
    valign: 'middle'
    color: (1, 1, 1, 1)
    canvas.before:
        # Outer glow when active
        Color:
            rgba: (0.2, 0.6, 1.0, 0.3) if self.active else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.x - 4, self.y - 4
            size: self.width + 8, self.height + 8
            radius: [16]
        # Main background
        Color:
            rgba: (0.18, 0.55, 1.0, 1.0) if self.active else (0.18, 0.18, 0.25, 1.0)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [12]
        # Top highlight (inner gloss)
        Color:
            rgba: (1, 1, 1, 0.18) if self.active else (1, 1, 1, 0.06)
        RoundedRectangle:
            pos: self.x + 4, self.y + self.height * 0.55
            size: self.width - 8, self.height * 0.35
            radius: [9]

<BandBar@BoxLayout>:
    channel: ''
    band: 'alpha'
    value: 0.0
    orientation: 'vertical'
    spacing: 2
    Label:
        text: root.channel + '\n' + root.band
        font_size: '9sp'
        size_hint_y: None
        height: '24dp'
        color: (0.7, 0.7, 0.7, 1)
        halign: 'center'
    Widget:
        canvas:
            # Track background
            Color:
                rgba: (0.1, 0.1, 0.15, 1)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [4]
            # Colored fill – green for alpha, orange for beta
            Color:
                rgba: (0.2, 0.85, 0.5, 1) if root.band == 'α' else (1.0, 0.55, 0.15, 1)
            Rectangle:
                pos: self.pos
                size: self.width * root.value, self.height

<QualityBar@BoxLayout>:
    channel: ''
    quality: 0.0
    orientation: 'vertical'
    spacing: 2
    Label:
        text: root.channel
        font_size: '9sp'
        size_hint_y: None
        height: '20dp'
        color: (0.7, 0.7, 0.7, 1)
        halign: 'center'
    Widget:
        canvas:
            # Track background
            Color:
                rgba: (0.1, 0.1, 0.15, 1)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [4]
            # Fill: red → yellow → green based on quality
            Color:
                r: max(0.0, 1.0 - root.quality * 2.0)
                g: min(1.0, root.quality * 2.0) * 0.85
                b: 0.05
                a: 1.0
            Rectangle:
                pos: self.pos
                size: self.width * root.quality, self.height

<DeviceRow@Button>:
    index: 0
    size_hint_y: None
    height: '44dp'
    background_color: (0.15, 0.15, 0.22, 1)
    color: (0.9, 0.9, 1.0, 1)
    on_release: app.root.get_screen('scan').connect_device(self.index)

# ─────────────────────────────────────────────────────────────────────────────
# Scan / Connect Screen
# ─────────────────────────────────────────────────────────────────────────────

<ScanScreen>:
    canvas.before:
        Color:
            rgba: (0.08, 0.08, 0.14, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: [24, 32, 24, 24]
        spacing: 14

        # Header
        Label:
            text: 'NeuroGaming'
            font_size: '28sp'
            bold: True
            size_hint_y: None
            height: '48dp'
            color: (0.4, 0.75, 1.0, 1)

        Label:
            text: 'Muse S Athena Controller  •  v' + app.version
            font_size: '14sp'
            size_hint_y: None
            height: '28dp'
            color: (0.65, 0.65, 0.8, 1)

        # Status
        Label:
            text: root.status_text
            font_size: '13sp'
            size_hint_y: None
            height: '36dp'
            color: (0.85, 0.85, 0.85, 1)
            text_size: self.size
            halign: 'center'
            valign: 'middle'

        # Scan button (pulses while scanning)
        Button:
            text: 'Scanning…' if root.is_scanning else 'Scan for Muse Devices'
            size_hint_y: None
            height: '50dp'
            font_size: '15sp'
            background_color: (0.18, 0.55, 1.0, 1)
            opacity: root.scan_pulse
            on_release: root.scan()

        # Device list
        ScrollView:
            size_hint_y: 1
            RecycleView:
                id: device_list
                data: [{'text': n, 'index': i} for i, n in enumerate(root.device_names)]
                viewclass: 'DeviceRow'
                RecycleBoxLayout:
                    orientation: 'vertical'
                    default_size: None, dp(44)
                    default_size_hint: 1, None
                    size_hint_y: None
                    height: self.minimum_height

        # Keyboard-only mode
        Button:
            text: 'Continue in keyboard-only mode (no Muse needed)'
            size_hint_y: None
            height: '46dp'
            font_size: '13sp'
            background_color: (0.25, 0.25, 0.35, 1)
            on_release: root.skip_to_keyboard()

        # Test screen
        Button:
            text: 'Test Screen – control blue dot'
            size_hint_y: None
            height: '46dp'
            font_size: '13sp'
            background_color: (0.1, 0.45, 0.2, 1)
            on_release: root.go_to_test()

# ─────────────────────────────────────────────────────────────────────────────
# Game Screen
# ─────────────────────────────────────────────────────────────────────────────

<GameScreen>:
    canvas.before:
        Color:
            rgba: (0.08, 0.08, 0.14, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: [16, 12, 16, 12]
        spacing: 10

        # ── Status bar ──
        BoxLayout:
            size_hint_y: None
            height: '36dp'
            spacing: 8
            Label:
                text: ('[color=44aaff][EEG][/color]' if root.connected else '[color=ffaa33][KB][/color]')
                markup: True
                size_hint_x: None
                width: '52dp'
                font_size: '13sp'
            Label:
                text: root.status_text
                font_size: '13sp'
                color: (0.85, 0.85, 0.85, 1)

        # ── Directional pad ──
        GridLayout:
            cols: 3
            rows: 3
            spacing: 8
            size_hint_y: 0.48

            # Row 1
            Widget:
            DirectionButton:
                label: '▲'
                active: root.direction == 'FORWARD'
            Widget:

            # Row 2
            DirectionButton:
                label: '◄'
                active: root.direction == 'LEFT'
            # Centre: current key label
            Label:
                text: root.direction if root.direction != 'NONE' else ''
                font_size: '11sp'
                bold: True
                color: (0.6, 0.6, 0.8, 1)
                halign: 'center'
                valign: 'middle'
            DirectionButton:
                label: '►'
                active: root.direction == 'RIGHT'

            # Row 3
            Widget:
            DirectionButton:
                label: '▼'
                active: root.direction == 'BACKWARD'
            Widget:

        # ── EEG band-power bars ──
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.17
            spacing: 4

            Label:
                text: 'EEG Band Power'
                font_size: '11sp'
                bold: True
                size_hint_y: None
                height: '18dp'
                color: (0.65, 0.65, 0.8, 1)

            BoxLayout:
                spacing: 6
                BandBar:
                    channel: 'AF7'
                    band: 'α'
                    value: root.alpha_left
                BandBar:
                    channel: 'AF8'
                    band: 'α'
                    value: root.alpha_right
                BandBar:
                    channel: 'AF7'
                    band: 'β'
                    value: root.beta_left
                BandBar:
                    channel: 'AF8'
                    band: 'β'
                    value: root.beta_right

        # ── Signal quality indicators ──
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.12
            spacing: 4

            Label:
                text: 'Signal Quality'
                font_size: '11sp'
                bold: True
                size_hint_y: None
                height: '18dp'
                color: (0.65, 0.65, 0.8, 1)

            BoxLayout:
                spacing: 6
                QualityBar:
                    channel: 'TP9'
                    quality: root.quality_tp9
                QualityBar:
                    channel: 'AF7'
                    quality: root.quality_af7
                QualityBar:
                    channel: 'AF8'
                    quality: root.quality_af8
                QualityBar:
                    channel: 'TP10'
                    quality: root.quality_tp10

        # ── Control buttons ──
        BoxLayout:
            size_hint_y: None
            height: '46dp'
            spacing: 8

            Button:
                text: 'Stop Calibration' if root.is_calibrating else 'Calibrate'
                font_size: '12sp'
                background_color: (0.8, 0.4, 0.1, 1) if root.is_calibrating else (0.18, 0.55, 1.0, 1)
                on_release: root.toggle_calibration()

            Button:
                text: 'Mode: ' + root.key_mode
                font_size: '12sp'
                background_color: (0.25, 0.25, 0.35, 1)
                on_release: root.toggle_key_mode()

            Button:
                text: 'Disconnect'
                font_size: '12sp'
                background_color: (0.6, 0.15, 0.15, 1)
                on_release: root.disconnect()

# ─────────────────────────────────────────────────────────────────────────────
# Test Screen
# ─────────────────────────────────────────────────────────────────────────────

<TestScreen>:
    # Dark background + glow rings + movable dot drawn behind all children
    canvas.before:
        Color:
            rgba: (0.05, 0.05, 0.1, 1)
        Rectangle:
            pos: self.pos
            size: self.size
        # Outer glow
        Color:
            rgba: root.dot_color[0], root.dot_color[1], root.dot_color[2], root.dot_color[3] * 0.2
        Ellipse:
            pos: root.dot_x - root.dot_radius * 2.2, root.dot_y - root.dot_radius * 2.2
            size: root.dot_radius * 4.4, root.dot_radius * 4.4
        # Mid glow
        Color:
            rgba: root.dot_color[0], root.dot_color[1], root.dot_color[2], root.dot_color[3] * 0.4
        Ellipse:
            pos: root.dot_x - root.dot_radius * 1.5, root.dot_y - root.dot_radius * 1.5
            size: root.dot_radius * 3, root.dot_radius * 3
        # Main dot
        Color:
            rgba: root.dot_color
        Ellipse:
            pos: root.dot_x - root.dot_radius, root.dot_y - root.dot_radius
            size: root.dot_radius * 2, root.dot_radius * 2

    BoxLayout:
        orientation: 'vertical'
        padding: [16, 12, 16, 12]
        spacing: 8

        # ── Title bar ──
        Label:
            text: 'Test Screen'
            font_size: '20sp'
            bold: True
            size_hint_y: None
            height: '40dp'
            color: (0.4, 0.75, 1.0, 1)
            halign: 'center'

        # ── Play area (transparent – dot shows through) ──
        Widget:
            size_hint_y: 1

        # ── Instructions ──
        Label:
            text: 'W/S/\u2191/\u2193 \u2013 move up/down     A/D/\u2190/\u2192 \u2013 move left/right'
            font_size: '10sp'
            size_hint_y: None
            height: '20dp'
            color: (0.5, 0.5, 0.7, 1)
            halign: 'center'

        Label:
            text: 'LMB \u2013 action flash     RMB \u2013 reset position'
            font_size: '10sp'
            size_hint_y: None
            height: '20dp'
            color: (0.5, 0.5, 0.7, 1)
            halign: 'center'

        # ── Status ──
        Label:
            text: root.status_text
            font_size: '11sp'
            size_hint_y: None
            height: '26dp'
            color: (0.85, 0.85, 0.85, 1)
            halign: 'center'
            text_size: self.size
            valign: 'middle'

        # ── Mouse-button state + Back button ──
        BoxLayout:
            size_hint_y: None
            height: '46dp'
            spacing: 8

            Label:
                text: 'LMB: ' + ('[color=33ff66]ACTIVE[/color]' if root.left_active else '[color=666688]idle[/color]')
                markup: True
                font_size: '13sp'
                bold: True
                halign: 'center'
                valign: 'middle'

            Label:
                text: 'RMB: ' + ('[color=ff5555]ACTIVE[/color]' if root.right_active else '[color=666688]idle[/color]')
                markup: True
                font_size: '13sp'
                bold: True
                halign: 'center'
                valign: 'middle'

            Button:
                text: '\u2190 Back'
                font_size: '13sp'
                size_hint_x: 0.4
                background_color: (0.25, 0.25, 0.35, 1)
                on_release: root.go_back()
